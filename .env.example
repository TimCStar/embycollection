# `.env.example` - 请重命名为 `.env` 并填写实际值
# 注意：**千万不要把真实的 .env 文件提交到 GitHub！**

# ========= Emby 服务器配置 =========
EMBY_SERVER=http://192.168.1.100:8096
EMBY_API_KEY=your_emby_api_key_here
EMBY_USER_ID=your_emby_user_id_here

# 可选：限制扫描的库 ID（逗号分隔），为空则扫描所有电影
LIBRARY_IDS=

# ========= 排行榜 API 配置 =========
RANK_API_URL=http://192.168.1.100:8043/api/v1/rank/share
RANK_API_KEY=your_rank_api_key_here
MAX_RANK_SIZE=100

# ========= 物理文件夹同步设置 =========
ENABLE_FOLDER_COPY=True
COPY_TARGET_DIR=/root
